FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      nut;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];


internalField   uniform 0;

boundaryField 
{ 
    inletAir
    {
        type    calculated;
        value   uniform 0;
    }
    inletH2
    {
        type    calculated;
        value   uniform 0;
    }
    wall
    {
        type    nutUWallFunction;
        value   uniform 0;
    }
    outlet
    {
        type    calculated;
        value   uniform 0;
    }
    wedgeLeft_1
    {
        type    cyclicAMI;
    }
    wedgeRight_1
    {
        type    cyclicAMI;
    }
} 


