#!/bin/bash
#SBATCH --nodes=4               # number of requested nodes
#SBATCH --exclusive
#SBATCH --ntasks-per-node=40
#SBATCH --output=output_%A.out  # where to redirect STDOUT
#SBATCH --time 24:00:00         # maximum walltime this job will use, allowed maximum is 24h
#SBATCH --job-name dakota       # job name
#SBATCH --partition a_test

# make sure dakota is loaded and the geom_opt conda environment is active!

# sample the design space
dakota -i dakota_sampling.in

